// 1. Le Générateur (Unique)
generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

// 2. La Source de données (Unique et sans URL car gérée par prisma.config.ts)
datasource db {
  provider = "postgresql"
}

// 3. Tes Modèles
model User {
  id                String             @id @default(uuid())
  name              String
  email             String             @unique
  imageUrl          String?            // Photo de profil Clerk (Google, GitHub, etc.)
  tasks             Task[]
  createdTasks      Task[]             @relation("CreatedTasks")
  projects          Project[]          @relation("UserProjects")
  userProjects      ProjectUser[]
  pushSubscriptions PushSubscription[]
}

// Abonnements aux notifications push Web — stockés par utilisateur
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id              String              @id @default(uuid())
  name            String
  description     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tasks           Task[]
  inviteCode      String              @unique
  createdById     String
  createdBy       User                @relation("UserProjects", fields: [createdById], references: [id])
  users           ProjectUser[]
  // Configuration WIP par colonne pour le calcul R_WIP du SGR
  columnWIPConfig ColumnWIPConfig[]
  // Historique des scores SGR pour l'étude réflexive (section 4.2)
  sgrHistory           SGRHistory[]
  // Intégrations externes (GitHub, SonarCloud) — section 3.3
  externalIntegrations ExternalIntegration[]
}

// Limite WIP par colonne Kanban — alimente R_WIP dans l'algorithme SGR
model ColumnWIPConfig {
  id        String  @id @default(uuid())
  projectId String
  column    String  // "To Do" | "In Progress" | "Done"
  wipLimit  Int     @default(0) // 0 = pas de limite
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, column])
}

model Task {
  id                  String     @id @default(uuid())
  name                String
  description         String
  status              String     @default("To Do")
  // Priorité de la tâche : LOW | MEDIUM | HIGH
  priority            String     @default("MEDIUM")
  // Dates métier
  startDate           DateTime?  // Date de début planifiée (saisie par l'utilisateur)
  dueDate             DateTime?
  // Horodatages pour le calcul SGR (Cycle Time, Work Item Age, Throughput)
  startedAt           DateTime?  // Rempli automatiquement lors du passage en "In Progress"
  completedAt         DateTime?  // Rempli automatiquement lors du passage en "Done"
  projectId           String
  project             Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                User?      @relation(fields: [userId], references: [id])
  userId              String?
  createdById         String
  createdBy           User       @relation("CreatedTasks", fields: [createdById], references: [id])
  solutionDescription String?
  files               TaskFile[]
}

// Fichiers joints à une tâche — uploadés via Vercel Blob
model TaskFile {
  id        String   @id @default(uuid())
  taskId    String
  name      String   // Nom original du fichier
  url       String   // URL Vercel Blob
  size      Int      // Taille en bytes
  mimeType  String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// Historique des scores SGR — alimente la section 4.2 du mémoire (étude réflexive)
model SGRHistory {
  id        String   @id @default(uuid())
  projectId String
  sgr       Float    // Score Global de Risque [0, 100]
  niveau    String   // "faible" | "modéré" | "élevé" | "critique"
  alertes   String   // Alertes actives sérialisées en JSON
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectUser {
  id        String  @id @default(uuid())
  userId    String
  projectId String
  user      User    @relation(fields: [userId], references: [id])
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

// Intégrations externes par projet — GitHub et SonarCloud
// Chaque ligne lie un projet TaskManage à un dépôt ou projet externe
// Le secret HMAC permet de vérifier l'authenticité des webhooks entrants
model ExternalIntegration {
  id                 String   @id @default(uuid())
  projectId          String
  type               String   // "github" | "sonarqube"
  externalProjectRef String   // ex: "Mr-TounkS/taskmanage" (GitHub) ou "taskmanage" (SonarCloud)
  webhookSecret      String   // Secret HMAC-SHA256 généré lors de la configuration
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
}